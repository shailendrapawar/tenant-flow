{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Node App",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "--nolazy"],
      "program": "${workspaceFolder}/backend/src/bin/server.ts",
      "console": "integratedTerminal",
      "restart": true,
      "sourceMaps": true,
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
